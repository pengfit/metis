# ────────────────────────────────────────────────────
# Metis 诊断服务 — 环境变量
# ────────────────────────────────────────────────────
# 复制为 `.env` 并填值. 服务启动时自动加载.

# LLM 提供方 (现在只剩 dify — 唯一真 provider).
# 其他 (openclaw/openai/anthropic) 在 v1.1 退出.
LLM_PROVIDER=dify

# 模型名 (留空 → 用默认, 实际只在 Dify provider 时有用)
LLM_MODEL=

# ─── Dify 专用 (唯一真实 provider) ────────────────────
# Dify Chat Messages API. App 的 prompt 在 Dify Studio 里配置.
# 配置 app prompt 依据: Knowledge Base/_eval/prompt-v1.md
#
# DIFY_API_BASE   端点根 URL (默认 https://api.dify.ai/v1)
# DIFY_API_KEY    Dify app 的 API key (必填)
# DIFY_APP_ID     可选, 人类可读 app 名(如 "诊断"), 存于 inputs.app_id
# DIFY_USER       可选, 顶层 user id (默认 metis)
# DIFY_INPUT_VAR  Dify app 的输入变量名。workflow app 常叫 "USER_DESCRIPTION"
#                 (默认); chat app 一般用 "query"。在本项目诊断场景里:
#                   - app=workflow (对话式 workflow): DIFY_INPUT_VAR=USER_DESCRIPTION
#                   - app=chat       (基础 chatbot)  : DIFY_INPUT_VAR=query
DIFY_API_BASE=https://api.dify.ai/v1
DIFY_API_KEY=
***
DIFY_USER=

*** # DIFY_APP_ID=诊断
# DIFY_INPUT_VAR=USER_DESCRIPTION

# ─── Mock (测试用, 优先级最高) ─────────────────────
# MOCK=1   强制走 canned 响应, 忽略所有 provider 配置.

# 端口 (uvicorn --port 覆盖)
PORT=8000
