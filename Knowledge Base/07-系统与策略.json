[
  {
    "id": "K007",
    "name": "平均 / 顶尖（选目标对象）",
    "category": "系统与策略",
    "summary": "参照物决定天花板；和顶尖比你会更尖，和平均比你会平庸。",
    "diagnosis_tags": [
      "赛道疑问",
      "对标",
      "Reference group"
    ],
    "trigger": [
      "满足感缺失",
      "无紧迫感"
    ],
    "symptoms": [
      "自满",
      "看不到差距"
    ],
    "root_causes": [
      "错误对标"
    ],
    "interventions": [
      {
        "label": "选3个真正'顶尖'的人",
        "do": "不是行业大V,是'你够得着的TOP'",
