        "min": 3,
        "mark": "对照过"
      },
      {
        "label": "找'TOP1的1个具体行为'本周试",
        "do": "如'他们晨起做什么'",
        "when": "this_week",
        "min": 0,
        "mark": "试了1个"
      }
    ],
    "reflection_questions": [
      "我现在的对标是平均还是顶尖？"
    ],
    "related": [
      "K094",
      "K063",
      "K064"
    ]
  },
