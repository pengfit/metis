[
  {
    "id": "K043",
    "name": "创造优点",
    "category": "关系与社会",
    "summary": "优点是行为+反馈累积出来的；先假装并坚持到真实。",
    "diagnosis_tags": [
      "身份迷茫",
      "美德实践",
      "自我建构"
    ],
    "trigger": [
      "想成为 X 人",
      "等自己'够格'"
    ],
    "symptoms": [
      "自我叙事僵化",
      "等待标签匹配"
    ],
    "root_causes": [
      "身份先于行为"
    ],
    "interventions": [
      {
        "label": "选1个要练的优点,今天1个动作",
        "do": "如'勇敢'→今天主动问1次",
        "when": "today",
        "min": 1,
        "mark": "1动作做完"
      },
      {
        "label": "每天写'今日优势1条'",
        "do": "不是泛说,具体小事",
        "when": "today",
        "min": 2,
        "mark": "1条写好"
      },
      {
        "label": "30天实验:刻意练1个优点",
        "do": "看结果",
        "when": "this_week",
        "min": 0,
        "mark": "实验启动"
      }
    ],
    "reflection_questions": [
      "我想拥有的优点的每日实践是什么？"
    ],
    "related": [
      "K015",
      "K062",
      "K038"
    ]
  },
  {
