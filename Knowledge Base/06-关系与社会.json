      },
      {
        "label": "主动问'对方需要被听见的是什么'",
        "do": "30秒内",
        "when": "now",
        "min": 1,
        "mark": "问了"
      }
    ],
    "reflection_questions": [
      "对方此刻'需要被听见'的是什么？"
    ],
    "related": [
      "K020",
      "K034",
      "K099"
    ]
  },
  {
    "id": "K075",
    "name": "状态杠杆",
